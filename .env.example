# Copy to `.env` and fill in real values. Do not commit `.env`.
# Validated keys: see `src/config/env.validation.ts` (zod). Defaults: `src/config/configuration.ts`.

# -----------------------------------------------------------------------------
# Core (required for app bootstrap)
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# Required by env validation — MongoDB connection string
MONGO_URI=mongodb://localhost:27017/vitrina-check

# -----------------------------------------------------------------------------
# Redis (BullMQ + webhook dedup)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
# Optional; set if Redis requires AUTH
# REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Playwright / dispatch (optional — defaults exist in code)
# -----------------------------------------------------------------------------
# PLAYWRIGHT_USER_AGENT=
# PLAYWRIGHT_RETRY_COUNT_DEFAULT=1
# PLAYWRIGHT_NAVIGATION_TIMEOUT_MS=60000
# PLAYWRIGHT_NETWORK_IDLE_TIMEOUT_MS=10000
# PLAYWRIGHT_STABILIZE_DELAY_MS=1200
# PLAYWRIGHT_RESTART_EVERY=100
# PLAYWRIGHT_MAX_CONCURRENCY=2

# DISPATCH_SCHEDULER_POLL_INTERVAL_MINUTES=1
# DISPATCH_PARSER_POLL_INTERVAL_MINUTES=1
# Write artifacts/report_*.json after parse (default true; set false in prod)
# DISPATCH_PARSER_PERSIST_REPORT_FILE=true

# -----------------------------------------------------------------------------
# Telegram — Bot API (outbound)
# -----------------------------------------------------------------------------
# From @BotFather; required for real sendMessage / answerCallbackQuery
TELEGRAM_BOT_TOKEN=

# -----------------------------------------------------------------------------
# Telegram — Webhook (inbound)
# -----------------------------------------------------------------------------
# Used by auto-registration on service startup (setWebhook target).
# Example: https://api.example.com
# TELEGRAM_WEBHOOK_PUBLIC_BASE_URL=
# At least one of secret token OR path secret recommended for production.
# TELEGRAM_WEBHOOK_SECRET_TOKEN=
# TELEGRAM_WEBHOOK_PATH_SECRET=
# TELEGRAM_WEBHOOK_SECRET_HEADER_NAME=x-telegram-bot-api-secret-token
# TELEGRAM_WEBHOOK_MAX_BODY_BYTES=524288
# TELEGRAM_WEBHOOK_REQUEST_TIMEOUT_MS=0
# TELEGRAM_WEBHOOK_LOG_SUMMARY=false
# TELEGRAM_BOT_ID=
# TELEGRAM_WEBHOOK_DEDUPE_TTL_SECONDS=86400
# TELEGRAM_CALLBACK_DEDUPE_ENABLED=false
# TELEGRAM_CALLBACK_DEDUPE_TTL_SECONDS=300

# -----------------------------------------------------------------------------
# Telegram — Outbound rate limit + 429 (optional)
# -----------------------------------------------------------------------------
# TELEGRAM_OUTBOUND_GLOBAL_RATE_PER_SEC=22
# TELEGRAM_OUTBOUND_GLOBAL_BURST=25
# TELEGRAM_OUTBOUND_CHAT_RATE_PER_SEC=1
# TELEGRAM_OUTBOUND_CHAT_BURST=2
# TELEGRAM_OUTBOUND_429_DEFAULT_RETRY_SECONDS=5
# TELEGRAM_OUTBOUND_429_MAX_ROUNDS=30
# TELEGRAM_OUTBOUND_429_MAX_WAIT_MS=3600000

# -----------------------------------------------------------------------------
# Other (read in code but not in env.validation.ts)
# -----------------------------------------------------------------------------
# Mongoose createdAt/updatedAt offset if needed
# APP_TIMEZONE_OFFSET_MINUTES=0
